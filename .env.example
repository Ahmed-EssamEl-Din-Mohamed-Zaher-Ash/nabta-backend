DATABASE_URL="postgresql://postgres:password@localhost:5432/nabta_oms?schema=public"

# Use a long random string in production, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

PORT=4000

# production | development
NODE_ENV=development

# Comma-separated list of allowed frontend origins (NO trailing slash)
# Example: CORS_ORIGIN=https://nabta-oms.netlify.app,https://app.nabta.ae
CORS_ORIGIN=http://localhost:5173

# Admin account created/updated by `npx prisma db seed` (password is bcrypt-hashed before storage)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_NAME=Admin
